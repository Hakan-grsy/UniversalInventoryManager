<Window x:Class="UniversalInventoryManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Inventory Manager | Professional Admin Panel" Height="600" Width="1000" WindowStartupLocation="CenterScreen"
        Background="#F0F2F5" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CFD8DC"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#37474F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="5,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#263238">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25">
                    <TextBlock Text="INVENTORY MASTER" FontWeight="Bold" FontSize="22" Foreground="White" Margin="0,0,0,20" HorizontalAlignment="Center" Opacity="0.9"/>
                    <Separator Background="#455A64" Margin="0,0,0,20"/>

                    <TextBlock Text="1. SELECT CATEGORY" FontWeight="Bold" Foreground="#90A4AE" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="RbTech" Content="Tech Product" Foreground="White" FontSize="14" IsChecked="True" Checked="Category_Checked" Margin="0,0,15,0"/>
                        <RadioButton x:Name="RbClothing" Content="Clothing Product" Foreground="White" FontSize="14" Checked="Category_Checked"/>
                    </StackPanel>

                    <TextBlock Text="2. GENERAL INFO" FontWeight="Bold" Foreground="#90A4AE" Margin="0,0,0,10"/>

                    <TextBlock Text="Product Name" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtName"/>

                    <TextBlock Text="Price ($)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtPrice"/>

                    <TextBlock Text="3. SPECIFIC DETAILS" FontWeight="Bold" Foreground="#90A4AE" Margin="0,15,0,10"/>

                    <Border x:Name="PanelTech" Background="#37474F" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <CheckBox x:Name="ChkBattery" Content="Has Battery Included?" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PanelClothing" Background="#37474F" CornerRadius="10" Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Size (S/M/L/XL)" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtSize"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnAddProduct" Content="💾 SAVE PRODUCT" Background="#0091EA" Margin="0,10,0,0" Click="BtnAddProduct_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Current Stock Overview" Grid.Row="0" FontSize="24" FontWeight="Light" Foreground="#37474F" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="5">
                <DataGrid x:Name="DgProducts" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE"
                          Background="White"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Price ($)" Binding="{Binding Price}" Width="100"/>

                        <DataGridTextColumn Header="Battery?" Binding="{Binding HasBattery}" Width="80"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>

            <Button x:Name="BtnDeleteSelected" 
                    Grid.Row="2" 
                    Content="DELETE SELECTED PRODUCT" 
                    Background="#D32F2F" 
                    Margin="0,15,0,0" 
                    HorizontalAlignment="Right" 
                    Width="220" 
                    Click="BtnDeleteSelected_Click"/>
        </Grid>
    </Grid>
</Window>